---
import DesignProcessLayout from "../../layouts/DesignProcessLayout.astro";
import {
  getDesignProcessNavSection,
  getDesignProcessNavSections,
} from "../../lib/design-process";

export function getStaticPaths() {
  return getDesignProcessNavSections().map((section) => ({
    params: { section: section.id },
    props: { section },
  }));
}

const { section } = Astro.props;
const sections = getDesignProcessNavSections();
const resolvedSection = getDesignProcessNavSection(section.id) ?? section;
---

<DesignProcessLayout
  pageTitle={resolvedSection.label}
  summary={`Översikt för ${resolvedSection.label}. Välj ett dokument nedan.`}
  currentUrl={resolvedSection.url}
  sections={sections}
>
  <section>
    <p>
      Den här sektionen samlar dokumenten i <code>{resolvedSection.id}</code> och ger kunden en
      tydlig ingång till rätt del av design-processen.
    </p>
  </section>

  <section>
    <h2>Dokument i sektionen</h2>
    <div class="cards">
      {resolvedSection.docs.map((doc) => (
        <a class="card" href={doc.url}>
          <strong>{doc.title}</strong>
          <span>{doc.relativePath}</span>
        </a>
      ))}
    </div>
  </section>
</DesignProcessLayout>

<style>
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }

  .card {
    display: grid;
    gap: 10px;
    text-decoration: none;
    padding: 18px;
    border-radius: 18px;
    border: 1px solid rgba(35, 24, 17, 0.12);
    background: rgba(180, 44, 34, 0.04);
  }

  .card:hover {
    border-color: rgba(180, 44, 34, 0.24);
    background: rgba(180, 44, 34, 0.08);
  }

  .card span {
    color: #6b5b52;
    font-size: 0.92rem;
    word-break: break-word;
  }
</style>
