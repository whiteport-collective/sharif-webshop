<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Sharif Design Process</title>
  </head>
  <body>
    <main class="hero">
      <div class="panel">
        <p class="eyebrow">Sharif</p>
        <h1>Design Process Viewer</h1>
        <p class="intro">
          En publik läsvy för brief, trigger map, UX-scenarier och designspecar utan att kunden
          behöver navigera i GitHub.
        </p>
        <div class="actions">
          <a class="primary" href="/design-process">Öppna design-processen</a>
          <a class="secondary" href="/design-process/C-UX-Scenarios/00-ux-scenarios">
            Gå direkt till UX-scenarier
          </a>
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #efe7db;
    --text: #231811;
    --muted: #66594f;
    --accent: #b42c22;
    --accent-strong: #8d2018;
    --line: rgba(35, 24, 17, 0.12);
    --shadow: 0 30px 90px rgba(35, 24, 17, 0.16);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(circle at top left, rgba(180, 44, 34, 0.14), transparent 28%),
      linear-gradient(180deg, #f6f0e6 0%, var(--bg) 100%);
    color: var(--text);
    font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
  }

  .hero {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 24px;
  }

  .panel {
    width: min(720px, 100%);
    padding: 40px;
    border-radius: 32px;
    border: 1px solid var(--line);
    background: rgba(255, 251, 245, 0.88);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.82rem;
    font-weight: 800;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 4.4rem);
    line-height: 0.95;
  }

  .intro {
    margin: 18px 0 0;
    max-width: 44ch;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
  }

  .primary {
    background: var(--accent);
    color: white;
  }

  .primary:hover {
    background: var(--accent-strong);
  }

  .secondary {
    border: 1px solid rgba(180, 44, 34, 0.18);
    background: rgba(180, 44, 34, 0.06);
    color: var(--accent);
  }

  .secondary:hover {
    background: rgba(180, 44, 34, 0.1);
  }

  @media (max-width: 720px) {
    .hero {
      padding: 16px;
    }

    .panel {
      padding: 28px;
      border-radius: 24px;
    }

    .actions {
      display: grid;
    }
  }
</style>
