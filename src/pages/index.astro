---
import HarrietFlow from "../components/sharif/HarrietFlow.svelte";
import SharifLayout from "../layouts/SharifLayout.astro";
import { getFlowBootstrapData } from "../lib/flow";

const bootstrap = await getFlowBootstrapData();
---

<SharifLayout
  title="Sharif | Harriet Flow Prototype"
  description="Astro + Svelte + Tailwind + daisyUI implementation of Harriet's tire purchase flow."
>
  <HarrietFlow client:load bootstrap={bootstrap} />
</SharifLayout>
