---
import type { DesignNavSection } from "../lib/design-process";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

interface Props {
  pageTitle: string;
  summary?: string;
  currentUrl?: string;
  sections: DesignNavSection[];
  headings?: Heading[];
}

const {
  pageTitle,
  summary = "Sharif design process",
  currentUrl = "",
  sections,
  headings = [],
} = Astro.props;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} | Sharif Design Process</title>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <a class="brand" href="/design-process">
          <span class="brand-mark">SHARIF</span>
          <span class="brand-copy">Design Process</span>
        </a>

        <nav class="nav" aria-label="Design process documents">
          {sections.map((section) => (
            <section class="nav-section">
              <h2>{section.label}</h2>
              <ul>
                {section.docs.map((doc) => (
                  <li class={doc.url === currentUrl ? "active" : ""}>
                    <a
                      href={doc.url}
                      style={`--depth:${doc.depth};`}
                      aria-current={doc.url === currentUrl ? "page" : undefined}
                    >
                      {doc.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </nav>
      </aside>

      <main class="content">
        <header class="topbar">
          <div>
            <p class="eyebrow">Customer Viewer</p>
            <h1>{pageTitle}</h1>
            <p class="summary">{summary}</p>
          </div>
          <a class="home-link" href="/">Till startsidan</a>
        </header>

        <div class="document-frame">
          <article class="document">
            <slot />
          </article>

          {headings.length > 0 && (
            <aside class="toc" aria-label="Table of contents">
              <p class="toc-label">På sidan</p>
              <ul>
                {headings
                  .filter((heading) => heading.depth <= 3)
                  .map((heading) => (
                    <li>
                      <a href={`#${heading.slug}`} style={`--depth:${heading.depth};`}>
                        {heading.text}
                      </a>
                    </li>
                  ))}
              </ul>
            </aside>
          )}
        </div>
      </main>
    </div>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f4efe6;
    --panel: rgba(255, 252, 246, 0.9);
    --panel-strong: #fffaf1;
    --line: rgba(35, 24, 17, 0.12);
    --line-strong: rgba(35, 24, 17, 0.2);
    --text: #231811;
    --muted: #6b5b52;
    --accent: #b42c22;
    --accent-soft: rgba(180, 44, 34, 0.08);
    --shadow: 0 24px 80px rgba(35, 24, 17, 0.12);
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 10px;
    --max-width: 1440px;
    --mono: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(circle at top right, rgba(180, 44, 34, 0.12), transparent 30%),
      linear-gradient(180deg, #f7f1e6 0%, #f0e8dc 100%);
    color: var(--text);
    font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
  }

  a {
    color: inherit;
  }

  .shell {
    width: min(var(--max-width), calc(100vw - 32px));
    margin: 16px auto;
    display: grid;
    grid-template-columns: 320px minmax(0, 1fr);
    gap: 20px;
    align-items: start;
  }

  .sidebar,
  .content {
    min-width: 0;
  }

  .sidebar {
    position: sticky;
    top: 16px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(18px);
    box-shadow: var(--shadow);
    padding: 20px;
    max-height: calc(100vh - 32px);
    overflow: auto;
  }

  .brand {
    display: grid;
    gap: 6px;
    text-decoration: none;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }

  .brand-mark {
    display: inline-flex;
    width: fit-content;
    padding: 8px 10px;
    border-radius: 999px;
    background: var(--accent);
    color: white;
    font-weight: 800;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
  }

  .brand-copy {
    font-size: 1.2rem;
    font-weight: 700;
  }

  .nav {
    display: grid;
    gap: 18px;
  }

  .nav-section h2 {
    margin: 0 0 10px;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .nav-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 4px;
  }

  .nav-section a {
    display: block;
    text-decoration: none;
    padding: 10px 12px;
    padding-left: calc(12px + (var(--depth, 0) * 18px));
    border-radius: var(--radius-sm);
    color: var(--muted);
    transition: background-color 0.16s ease, color 0.16s ease;
  }

  .nav-section a:hover,
  .nav-section li.active a {
    background: var(--accent-soft);
    color: var(--text);
  }

  .content {
    display: grid;
    gap: 20px;
  }

  .topbar {
    display: flex;
    gap: 16px;
    justify-content: space-between;
    align-items: flex-start;
    padding: 24px 28px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .eyebrow {
    margin: 0 0 8px;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    font-weight: 700;
  }

  .topbar h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1;
  }

  .summary {
    margin: 12px 0 0;
    max-width: 62ch;
    color: var(--muted);
  }

  .home-link {
    white-space: nowrap;
    text-decoration: none;
    color: var(--accent);
    font-weight: 700;
  }

  .document-frame {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 20px;
    align-items: start;
  }

  .document {
    background: var(--panel-strong);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 32px;
    box-shadow: var(--shadow);
    overflow: auto;
  }

  .document :global(h1),
  .document :global(h2),
  .document :global(h3),
  .document :global(h4) {
    scroll-margin-top: 24px;
    line-height: 1.12;
  }

  .document :global(h1) {
    margin-top: 0;
    font-size: clamp(2rem, 2.8vw, 2.8rem);
  }

  .document :global(h2) {
    margin-top: 2.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    font-size: 1.4rem;
  }

  .document :global(h3) {
    font-size: 1.08rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .document :global(p),
  .document :global(li) {
    line-height: 1.7;
  }

  .document :global(a) {
    color: var(--accent);
  }

  .document :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    border: 1px solid var(--line);
    background: white;
    box-shadow: 0 12px 40px rgba(35, 24, 17, 0.08);
  }

  .document :global(table) {
    width: 100%;
    border-collapse: collapse;
    display: block;
    overflow-x: auto;
    margin: 1.25rem 0;
    font-size: 0.95rem;
  }

  .document :global(th),
  .document :global(td) {
    border: 1px solid var(--line);
    padding: 10px 12px;
    text-align: left;
    vertical-align: top;
  }

  .document :global(th) {
    background: rgba(35, 24, 17, 0.04);
  }

  .document :global(code) {
    font-family: var(--mono);
    font-size: 0.92em;
    background: rgba(35, 24, 17, 0.06);
    padding: 0.15em 0.35em;
    border-radius: 6px;
  }

  .document :global(pre) {
    overflow-x: auto;
    padding: 16px;
    border-radius: var(--radius-md);
    background: #1a1512;
    color: #f7f1e6;
  }

  .document :global(hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin: 2rem 0;
  }

  .toc {
    position: sticky;
    top: 16px;
    padding: 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .toc-label {
    margin: 0 0 12px;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 700;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }

  .toc a {
    display: block;
    text-decoration: none;
    color: var(--muted);
    padding-left: calc((var(--depth, 1) - 1) * 12px);
  }

  .toc a:hover {
    color: var(--accent);
  }

  @media (max-width: 1100px) {
    .shell {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      max-height: none;
    }

    .document-frame {
      grid-template-columns: 1fr;
    }

    .toc {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .shell {
      width: min(100vw - 16px, var(--max-width));
      margin: 8px auto;
      gap: 12px;
    }

    .sidebar,
    .topbar,
    .document,
    .toc {
      border-radius: 20px;
      padding: 20px;
    }

    .topbar {
      flex-direction: column;
    }
  }
</style>
